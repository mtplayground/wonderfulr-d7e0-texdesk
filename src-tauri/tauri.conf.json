{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wonderfulr-d7e0-texdesk",
  "version": "0.1.0",
  "identifier": "com.mctai.wonderfulr-d7e0-texdesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "cd .. && npm ci && npm run build",
    "devUrl": "http://localhost:8080",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "wonderfulr-d7e0-texdesk",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "mtplayground",
    "copyright": "Copyright (c) 2026 mtplayground",
    "category": "DeveloperTool",
    "shortDescription": "A local desktop LaTeX workspace.",
    "longDescription": "wonderfulr-d7e0-texdesk is a native desktop workspace for editing LaTeX course assignments, compiling them with a local TeX toolchain, and previewing the resulting PDF.",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
